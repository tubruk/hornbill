# Example environment configuration for Hornbill
# -------------------------------------------------
# Server settings
PORT=3000
# Trailbase database URL (adjust if running Trailbase elsewhere)
TRAILBASE_URL=http://localhost:4000

# Feature toggles
REGISTRATION_ENABLED=true   # Set to false to hide registration UI
SYNC_INTERVAL_MINUTES=60   # Background sync interval (minutes)

# Trailbase data directory – ensure the path is writable
TRAILBASE_DATA_DIR=./data/hornbill
