# Example environment configuration for Hornbill
# -------------------------------------------------
# Server settings
PORT=3000
# Trailbase database URL (adjust if running Trailbase elsewhere)
TRAILBASE_URL=http://localhost:4000

# Feature toggles
REGISTRATION_ENABLED=true   # Set to false to hide registration UI
SYNC_INTERVAL_MINUTES=1440  # Background sync interval (minutes)

# Security / secrets (replace with strong, random values in production)
JWT_SECRET=change_this_to_a_strong_secret
# If using external services, add their credentials here, e.g.:
# EMAIL_SMTP_HOST=smtp.example.com
# EMAIL_SMTP_USER=example_user
# EMAIL_SMTP_PASS=example_password

# Database file (SQLite) – ensure the path is writable
DATABASE_URL=./data/hornbill.db
