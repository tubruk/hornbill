{
  "name": "hornbill-monorepo",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun --filter hornbill-web dev",
    "dev:api": "bun --filter hornbill-api dev",
    "dev": "concurrently -n \"api,web\" -c \"blue,magenta\" \"bun run dev:api\" \"bun run dev:web\"",
    "test": "bun test --recursive",
    "coverage": "bun scripts/coverage.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "bun --filter '*' typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.2",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "yaml": "^2.9.0"
  }
}
