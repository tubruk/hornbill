{
  "name": "hornbill-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun --filter web dev",
    "dev:api": "bun --filter api dev",
    "dev": "concurrently -n \"api,web\" -c \"blue,magenta\" \"bun run dev:api\" \"bun run dev:web\"",
    "test": "bun test --recursive"
  },
  "devDependencies": {
    "concurrently": "^10.0.0"
  }
}
